# ============================================
# IPTV 智能整理平台 - 环境变量配置
# ============================================

# ========== 运行模式 ==========
# once: 执行一次后退出
# schedule: 定时执行
RUN_MODE=schedule
SCHEDULE_INTERVAL=21600

# ========== 自治模式配置（新架构） ==========
# true: 启用自治模式（源池→候选版→稳定版→质量回路）
# false: 使用传统模式（默认）
AUTONOMOUS_MODE=false

# 自治模式子配置（仅当 AUTONOMOUS_MODE=true 时生效）
# 是否自动更新稳定版
AUTO_UPDATE_STABLE=true
# 是否自动替换失效源
AUTO_REPLACE_FAILED=true
# 质量检查间隔（小时）
QUALITY_CHECK_INTERVAL=24
# 候选源观察期（小时）
CANDIDATE_OBSERVATION_HOURS=24
# 候选源稳定所需最少成功次数
CANDIDATE_MIN_SUCCESS=10
# 候选源最低成功率（0.0-1.0）
CANDIDATE_MIN_SUCCESS_RATE=0.8
# 候选源最大平均延迟（毫秒）
CANDIDATE_MAX_LATENCY=2000

# ========== 性能配置 ==========
MAX_WORKERS=20
TIMEOUT=8

# ========== 验证配置 ==========
FFMPEG_ENABLE=true

# ========== 缓存配置 ==========
# 常规缓存时长（小时）
CACHE_HOURS=24
# 原始源缓存时长（小时）- 建议延长
CACHE_RAW_HOURS=48
# 测速结果缓存时长（小时）
CACHE_SPEED_HOURS=24
# 是否启用增量更新（只拉取变化的源）
ENABLE_INCREMENTAL_FETCH=true

# ========== 频道管理 ==========
# 每个频道保留的源数量（用于自动切换）
MAX_SOURCES_PER_CHANNEL=3

# ========== 输出配置 ==========
DEMO_MATCH_MODE=contains

# ========== 功能开关 ==========
ENABLE_DEMO_FILTER=true
ENABLE_ALIAS=true
ENABLE_BLACKLIST=true
DATABASE_ENABLE=true

# ========== Web 服务 ==========
WEB_SERVER_PORT=8080

# ========== iptv-org 融合配置 ==========
# 是否启用 iptv-org 适配器
IPTV_ORG_ENABLE=true
# iptv-org Logo CDN 地址
IPTV_ORG_CDN=https://raw.githubusercontent.com/iptv-org/iptv/master/resources
# 是否将 iptv-org 主列表加入采集源
IPTV_ORG_ADD_MAIN_LIST=true
# iptv-org 特殊缓存（该源变化慢）
IPTV_ORG_CACHE_HOURS=72

# ========== 全球频道配置 ==========
# 是否启用全球频道扩展（会增加大量海外频道）
ENABLE_GLOBAL_CHANNELS=false
# 全球频道数量限制（避免输出文件过大）
GLOBAL_CHANNELS_LIMIT=200

# ========== EPG 配置 ==========
# 是否启用 EPG 注入（为 M3U 添加 tvg-id）
ENABLE_EPG_INJECTION=true
# EPG 缓存天数
EPG_CACHE_DAYS=7

# ========== 输出格式配置 ==========
# 是否生成 JSON API 输出
ENABLE_JSON_OUTPUT=true
# 是否生成精简版（适合手机使用）
ENABLE_LITE_VERSION=true
# 是否生成 EPG 就绪版 M3U
ENABLE_EPG_OUTPUT=true
